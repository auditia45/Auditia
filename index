@charset "utf-8";

.rc-step { display: none; }

.rc-step.on { display: block; }

.rc-model-card { border: 2px solid var(--n2); border-radius: 12px; padding: 14px 10px; text-align: center; cursor: pointer; transition: 0.18s; background: var(--n4); }

.rc-model-card.on { border-color: rgb(183, 28, 28); background: rgb(255, 235, 238); }

.rc-type-btn { padding: 8px 14px; border-radius: 18px; border: 1.5px solid var(--n2); background: none; cursor: pointer; font-size: 0.8rem; font-family: Raleway, sans-serif; font-weight: 700; color: var(--n1); }

.rc-type-btn.on { background: rgb(183, 28, 28); color: rgb(255, 255, 255); border-color: rgb(183, 28, 28); }

.rc-imp-btn { padding: 7px 12px; border-radius: 18px; border: 1.5px solid var(--n2); background: none; cursor: pointer; font-size: 0.78rem; font-family: Raleway, sans-serif; font-weight: 700; color: var(--n1); }

.rc-imp-btn.on { background: rgb(183, 28, 28); color: rgb(255, 255, 255); border-color: rgb(183, 28, 28); }

.rc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }

.rc-tag { padding: 5px 10px; border-radius: 14px; border: 1.5px solid var(--n2); background: var(--n3); cursor: pointer; font-size: 0.76rem; font-family: Raleway, sans-serif; font-weight: 600; color: var(--n1); transition: 0.15s; user-select: none; }

.rc-tag.on { background: rgb(183, 28, 28); color: rgb(255, 255, 255); border-color: rgb(183, 28, 28); }

.rc-lbl { font-size: 0.78rem; font-weight: 700; font-family: Raleway, sans-serif; color: var(--n1); display: block; margin-bottom: 4px; }

.rc-step-dot { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.72rem; font-weight: 800; font-family: Raleway, sans-serif; flex-shrink: 0; transition: 0.2s; }

.rc-step-dot.done { background: rgb(183, 28, 28); color: rgb(255, 255, 255); }

.rc-step-dot.current { background: rgb(183, 28, 28); color: rgb(255, 255, 255); box-shadow: rgb(255, 205, 210) 0px 0px 0px 3px; }

.rc-step-dot.todo { background: var(--n2); color: var(--n1); }

.rc-temoin-block { background: var(--n3); border-radius: 10px; padding: 10px; margin-bottom: 8px; }

.rc-photo-thumb { width: 70px; height: 70px; object-fit: cover; border-radius: 8px; border: 2px solid var(--n2); }

.rc-list-card { background: var(--n4); border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; box-shadow: var(--sh); cursor: pointer; border-left: 4px solid rgb(183, 28, 28); }

.rc-list-meta { font-size: 0.74rem; color: var(--n1); margin-top: 4px; }
