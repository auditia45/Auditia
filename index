.bfo-title { font-family: Raleway, sans-serif; font-weight: 800; font-size: 0.85rem; flex: 1 1 0%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.bfo-btn { padding: 6px 11px; border-radius: 7px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; cursor: pointer; font-family: Raleway, sans-serif; font-weight: 700; font-size: 0.75rem; background: rgba(255, 255, 255, 0.15); color: rgb(255, 255, 255); }

.bfo-btn.primary { background: rgb(232, 98, 10); }

.bfo-btn:active { background: rgba(255, 255, 255, 0.28); }

#bat-fiche-content { flex: 1 1 0%; overflow-y: auto; padding: 14px; }

.bat-chart-bar { display: flex; align-items: flex-end; gap: 5px; height: 90px; padding: 0px 4px; margin: 8px 0px; }

.bat-chart-col { flex: 1 1 0%; display: flex; flex-direction: column; align-items: center; gap: 3px; }

.bat-chart-pct { font-size: 0.62rem; font-weight: 800; color: var(--n1); }

.bat-chart-fill { width: 100%; border-radius: 4px 4px 0px 0px; min-height: 4px; transition: height 0.3s; }

.bat-chart-label { font-size: 0.58rem; color: var(--n1); text-align: center; line-height: 1.2; }

#toast { position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%); background: rgb(13, 42, 78); color: rgb(255, 255, 255); padding: 9px 18px; border-radius: 20px; font-family: Raleway, sans-serif; font-weight: 700; font-size: 0.8rem; box-shadow: rgba(0, 0, 0, 0.25) 0px 4px 16px; z-index: 600; opacity: 0; transition: opacity 0.25s; pointer-events: none; white-space: nowrap; }

#toast.show { opacity: 1; }

#toast.success { background: rgb(46, 125, 50); }

#toast.error { background: rgb(198, 40, 40); }

#toast.warning { background: rgb(230, 81, 0); }

@keyframes cl-flash-anim { 
  0% { background: transparent; }
  30% { background: rgba(232, 98, 10, 0.15); }
  100% { background: transparent; }
}

.cl-flash { animation: 0.6s ease 0s 1 normal none running cl-flash-anim; }

.duerp-hero { background: linear-gradient(135deg, rgb(27, 94, 32), rgb(46, 125, 50)); color: rgb(255, 255, 255); border-radius: 18px; padding: 18px 16px; margin-bottom: 14px; box-shadow: var(--sh2); }

.duerp-hero h1 { font-family: Raleway, sans-serif; font-weight: 900; font-size: 1.05rem; letter-spacing: -0.3px; margin: 0px; }

.duerp-hero p { font-size: 0.75rem; opacity: 0.85; margin-top: 4px; margin-bottom: 0px; }

.duerp-tabs { display: flex; gap: 5px; margin-bottom: 12px; overflow-x: auto; scrollbar-width: none; flex-wrap: nowrap; }

.duerp-tabs::-webkit-scrollbar { display: none; }

.duerp-tab { padding: 5px 13px; border-radius: 18px; border: 1.5px solid var(--n2); background: none; cursor: pointer; font-size: 0.76rem; font-family: Raleway, sans-serif; font-weight: 700; color: var(--n1); transition: 0.18s; white-space: nowrap; flex-shrink: 0; }

.duerp-tab.on { background: rgb(46, 125, 50); color: rgb(255, 255, 255); border-color: rgb(46, 125, 50); }

.duerp-ut-card { background: var(--n4); border-radius: 12px; margin-bottom: 10px; box-shadow: var(--sh); overflow: hidden; }

.duerp-ut-head { background: linear-gradient(135deg, rgb(27, 94, 32), rgb(46, 125, 50)); color: rgb(255, 255, 255); padding: 10px 14px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }

.duerp-ut-head h3 { font-family: Raleway, sans-serif; font-weight: 800; font-size: 0.88rem; letter-spacing: -0.2px; margin: 0px; }

.duerp-ut-body { padding: 12px 14px; display: none; }

.duerp-ut-body.open { display: block; }

.duerp-risk-row { border-bottom: 1px solid var(--n2); padding: 8px 0px; font-size: 0.8rem; }

.duerp-risk-row:last-child { border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }

.duerp-risk-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 4px; }

.duerp-risk-lib { font-weight: 600; color: var(--tx); flex: 1 1 0%; line-height: 1.4; font-size: 0.81rem; }

.duerp-risk-badge { font-family: Raleway, sans-serif; font-weight: 800; font-size: 0.72rem; padding: 2px 8px; border-radius: 9px; white-space: nowrap; }

.duerp-risk-badge.faible { background: var(--g3); color: var(--g1); }

.duerp-risk-badge.moyen { background: var(--o3); color: var(--o1); }

.duerp-risk-badge.fort { background: var(--r3); color: var(--r1); }

.duerp-risk-meta { font-size: 0.72rem; color: var(--n1); display: flex; gap: 10px; flex-wrap: wrap; margin-top: 2px; }

.duerp-risk-action { background: var(--n3); border-radius: 7px; padding: 5px 8px; margin-top: 5px; font-size: 0.77rem; color: var(--b1); }

.duerp-synth-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0px; border-bottom: 1px solid var(--n2); font-size: 0.82rem; }

.duerp-synth-row:last-child { border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }

.duerp-synth-ut { font-weight: 600; color: var(--b1); }

.duerp-synth-counts { display: flex; gap: 6px; }

.dsc { padding: 2px 8px; border-radius: 8px; font-size: 0.7rem; font-weight: 700; font-family: Raleway, sans-serif; }

.dsc.f { background: var(--r3); color: var(--r1); }

.dsc.m { background: var(--o3); color: var(--o1); }

.dsc.w { background: var(--g3); color: var(--g1); }

.duerp-import-zone { border: 2.5px dashed var(--n2); border-radius: 12px; padding: 22px; text-align: center; cursor: pointer; transition: border-color 0.2s; background: var(--n3); margin-bottom: 12px; }

.duerp-import-zone:hover, .duerp-import-zone.drag { border-color: rgb(46, 125, 50); background: rgb(232, 245, 233); }

.duerp-import-zone p { font-size: 0.82rem; color: var(--n1); margin-top: 6px; margin-bottom: 0px; }

.duerp-ai-panel { background: linear-gradient(135deg, rgb(232, 245, 233), rgb(241, 248, 233)); border: 1.5px solid rgb(165, 214, 167); border-radius: 12px; padding: 13px; margin-bottom: 12px; }

.duerp-ai-panel h3 { font-family: Raleway, sans-serif; font-weight: 800; font-size: 0.88rem; color: rgb(27, 94, 32); margin-bottom: 8px; margin-top: 0px; }

.duerp-ai-result { background: rgb(255, 255, 255); border-radius: 8px; padding: 10px; font-size: 0.8rem; color: var(--tx); margin-top: 8px; max-height: 220px; overflow-y: auto; line-height: 1.6; display: none; }

.duerp-papri-row { border-left: 4px solid var(--n2); padding: 9px 12px; margin-bottom: 8px; background: var(--n3); border-radius: 0px 10px 10px 0px; font-size: 0.8rem; }

.duerp-papri-row.p1 { border-left-color: var(--r2); }

.duerp-papri-row.p2 { border-left-color: var(--o2); }

.duerp-papri-row.p3 { border-left-color: var(--b2); }

.duerp-papri-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 3px; }

.duerp-papri-action { font-weight: 600; color: var(--tx); flex: 1 1 0%; font-size: 0.83rem; }

.duerp-papri-meta { font-size: 0.71rem; color: var(--n1); margin-top: 4px; display: flex; gap: 10px; flex-wrap: wrap; }

.duerp-cota-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 7px; margin: 4px 0px; }

.duerp-cota-row select { font-size: 0.82rem; padding: 6px 8px; }

.duerp-rr-display { background: var(--b2); color: rgb(255, 255, 255); border-radius: 8px; padding: 8px 12px; text-align: center; font-family: Raleway, sans-serif; font-weight: 900; font-size: 1.1rem; margin: 8px 0px; }

.duerp-rr-display.faible { background: var(--g2); }

.duerp-rr-display.moyen { background: var(--o2); }

.duerp-rr-display.fort { background: var(--r2); }

.screen-ref { font-size: 9px; font-weight: 400; opacity: 0.35; margin-left: 6px; font-family: monospace; letter-spacing: 0.3px; vertical-align: middle; }

.pg-num { position: fixed; bottom: 6px; right: 8px; font-size: 9px; color: rgba(0, 0, 0, 0.18); font-family: monospace; pointer-events: none; z-index: 10; letter-spacing: 0.5px; }
